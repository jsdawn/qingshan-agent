{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "inputs": ["src/**", "package.json", "tsconfig.json"]
    },
    "build": {
      "outputs": ["dist/**", "build/**"],
      "cache": true,
      "inputs": ["src/**", "package.json", "tsconfig.json"]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"]
    },
    "lint": {
      "cache": true
    },
    "clean": {
      "cache": false
    }
  }
}
