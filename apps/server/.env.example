# ==================== AI 配置（通用 OpenAI 兼容接口）====================
# 支持任何 OpenAI 兼容的 AI 提供商，只需修改这些配置即可切换，无需改源码

# 示例: 硅基流动（推荐，速度快，成本低）
# AI_BASE_URL=https://api.siliconflow.cn/v1
# AI_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
# AI_API_KEY=your_siliconflow_api_key_here

# 示例: OpenAI
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4
# AI_API_KEY=your_openai_api_key_here

# 示例: DeepSeek
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat
# AI_API_KEY=your_deepseek_api_key_here

# 示例: Anthropic Claude
# AI_BASE_URL=https://api.anthropic.com/v1
# AI_MODEL=claude-3-opus-20240229
# AI_API_KEY=your_anthropic_api_key_here

# 示例: Anthropic Claude
# AI_BASE_URL=https://api.anthropic.com/v1
# AI_MODEL=claude-3-opus-20240229
# AI_API_KEY=your_anthropic_api_key_here

## 智谱AI
# AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# AI_MODEL=glm-5
# AI_API_KEY=your_anthropic_api_key_here

# 默认配置（硅基流动）
AI_BASE_URL=https://api.siliconflow.cn/v1
AI_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
AI_API_KEY=sk_replace_with_your_api_key

# AI 模型参数
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2048

# ==================== 服务器配置 ====================
PORT=3000
NODE_ENV=development

# 前端 URL（用于 CORS 配置）
FRONTEND_URL=http://localhost:5173
